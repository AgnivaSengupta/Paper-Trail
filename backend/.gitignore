logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime files
*.pid
*.pid.lock
*.seed

# Coverage
coverage/
.nyc_output/

# Caches
.cache/
.turbo/

# Local uploads and temp files
uploads/
media/
tmp/
temp/

# Editor / OS clutter
.DS_Store
Thumbs.db

